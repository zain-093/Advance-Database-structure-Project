@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="error-page fade-in">
    <div>
        <div class="error-icon">
            <i class="fas fa-exclamation-triangle"></i>
        </div>
        <h1>Something Went Wrong</h1>
        <p>An error occurred while processing your request.</p>

        @if (Model.ShowRequestId)
        {
            <p style="margin-top: 16px;">
                <strong style="color: var(--text-secondary);">Request ID:</strong> 
                <code>@Model.RequestId</code>
            </p>
        }

        <a asp-controller="Home" asp-action="Index" class="btn-primary-custom" style="margin-top: 24px;" id="error-home-btn">
            <i class="fas fa-home"></i> Back to Home
        </a>
    </div>
</div>
