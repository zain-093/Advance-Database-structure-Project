@{
    ViewData["Title"] = "Access Denied";
}

<div class="empty-state fade-in" style="max-width: 600px; margin: 80px auto;">
    <i class="fas fa-hand-paper" style="font-size: 64px; color: var(--danger); margin-bottom: 24px;"></i>
    <h2 style="font-weight: 700; color: var(--text-primary); margin-bottom: 12px;">Access Denied</h2>
    <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 32px;">
        You do not have permission to view this resource. This page requires specific privileges 
        which are not assigned to your current role. Row-Level Security and Access Policies are active.
    </p>
    <div style="display: flex; gap: 16px; justify-content: center;">
        <a href="/" class="btn-outline-custom">
            <i class="fas fa-home"></i> Back to Safety
        </a>
        <form asp-controller="Account" asp-action="Logout" method="post" style="display:inline;">
            <button type="submit" class="btn-primary-custom" style="background: linear-gradient(135deg, var(--danger), #e04444);">
                <i class="fas fa-right-from-bracket"></i> Switch Account
            </button>
        </form>
    </div>
</div>
