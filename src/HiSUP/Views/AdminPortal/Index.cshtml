@model HiSUP.Models.AdminPortalViewModel
@{
    ViewData["Title"] = "Portal Control Panel";
}

<!-- Custom Styles for Control Panel -->
<style>
    .custom-pills .nav-link {
        background: rgba(26, 31, 78, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        color: var(--text-secondary);
        font-weight: 600;
        font-size: 14px;
        padding: 10px 20px;
        border-radius: var(--radius-sm);
        transition: all 0.3s ease;
        margin-right: 8px;
        margin-bottom: 8px;
    }
    .custom-pills .nav-link:hover {
        background: rgba(79, 140, 255, 0.08);
        color: var(--text-primary);
        border-color: rgba(79, 140, 255, 0.2);
    }
    .custom-pills .nav-link.active {
        background: var(--accent-gradient);
        color: #fff;
        border-color: transparent;
        box-shadow: 0 4px 15px rgba(124, 92, 252, 0.25);
    }
    .table-section-title {
        font-size: 16px;
        font-weight: 700;
        margin: 24px 0 16px;
        padding-bottom: 8px;
        border-bottom: 2px solid rgba(255, 255, 255, 0.05);
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .form-card {
        background: rgba(26, 31, 78, 0.55);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: var(--radius-md);
        padding: 24px;
        margin-bottom: 24px;
    }
    .form-label-custom {
        font-size: 13px;
        color: var(--text-secondary);
        font-weight: 500;
        margin-bottom: 8px;
    }
    .form-control-portal {
        background: rgba(10, 14, 39, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: var(--radius-sm);
        color: var(--text-primary);
        padding: 8px 12px;
        font-size: 14px;
        outline: none;
        transition: border var(--transition-fast);
        width: 100%;
    }
    .form-control-portal:focus {
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 3px rgba(79, 140, 255, 0.15);
    }
    .btn-delete-record {
        background: none;
        border: none;
        color: var(--danger);
        cursor: pointer;
        font-size: 14px;
        transition: transform 0.2s ease;
    }
    .btn-delete-record:hover {
        transform: scale(1.15);
    }
    .badge-role {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 8px;
        border-radius: var(--radius-xl);
    }
    .badge-role.admin { background: rgba(124, 92, 252, 0.15); color: var(--accent-violet); border: 1px solid rgba(124, 92, 252, 0.25); }
    .badge-role.faculty { background: rgba(79, 140, 255, 0.15); color: var(--accent-blue); border: 1px solid rgba(79, 140, 255, 0.25); }
    .badge-role.student { background: rgba(0, 214, 143, 0.15); color: var(--success); border: 1px solid rgba(0, 214, 143, 0.25); }
    .badge-role.finance { background: rgba(255, 170, 44, 0.15); color: var(--warning); border: 1px solid rgba(255, 170, 44, 0.25); }
</style>

<!-- Page Header -->
<div class="page-header fade-in">
    <h1><i class="fas fa-cogs" style="color: var(--accent-blue);"></i> Control Panel Dashboard</h1>
    <p>Perform administrative operations, CRUD management, and track logs across HITECUNI_DB.</p>
</div>

<!-- Alert notifications -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: rgba(0, 214, 143, 0.1); border: 1px solid rgba(0, 214, 143, 0.2); color: var(--success); border-radius: 8px;">
        <i class="fas fa-check-circle mr-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="filter: invert(1);"></button>
    </div>
}

<!-- Tabbed Navigation Menu -->
<ul class="nav nav-pills custom-pills mb-4 fade-in" id="portalTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="academics-tab" data-bs-toggle="pill" data-bs-target="#academics" type="button" role="tab"><i class="fas fa-university"></i> Academics</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="people-tab" data-bs-toggle="pill" data-bs-target="#people" type="button" role="tab"><i class="fas fa-users"></i> People</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="registrations-tab" data-bs-toggle="pill" data-bs-target="#registrations" type="button" role="tab"><i class="fas fa-clipboard-list"></i> Registrations</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="finance-tab" data-bs-toggle="pill" data-bs-target="#finance" type="button" role="tab"><i class="fas fa-wallet"></i> Finance</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="services-tab" data-bs-toggle="pill" data-bs-target="#services" type="button" role="tab"><i class="fas fa-hotel"></i> Services</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="schedules-tab" data-bs-toggle="pill" data-bs-target="#schedules" type="button" role="tab"><i class="fas fa-calendar-alt"></i> Schedules</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="logs-tab" data-bs-toggle="pill" data-bs-target="#logs" type="button" role="tab"><i class="fas fa-shield-halved"></i> Audit Logs</button>
    </li>
</ul>

<!-- Tabs Contents -->
<div class="tab-content fade-in" id="portalTabsContent">

    <!-- 1. ACADEMICS TAB -->
    <div class="tab-pane fade show active" id="academics" role="tabpanel">
        
        <!-- Departments Table -->
        <div class="table-section-title">
            <span><i class="fas fa-building text-primary"></i> Departments</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addDeptCollapse"><i class="fas fa-plus"></i> Add Department</button>
        </div>
        
        <div class="collapse" id="addDeptCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Create New Department</h4>
                <form asp-action="CreateDepartment" method="post">
                    <div class="row">
                        <div class="col-md-5 mb-2">
                            <label class="form-label-custom">Department Name</label>
                            <input type="text" name="DepartmentName" class="form-control-portal" placeholder="e.g. Computer Science" required />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Code</label>
                            <input type="text" name="DepartmentCode" class="form-control-portal" placeholder="e.g. CS" required />
                        </div>
                        <div class="col-md-3 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Department Name</th>
                        <th>Code</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in Model.Departments)
                    {
                        <tr>
                            <td>#@d.DepartmentID</td>
                            <td style="color: #fff; font-weight: 500;">@d.DepartmentName</td>
                            <td><span class="badge-custom info">@d.DepartmentCode</span></td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteDepartment" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@d.DepartmentID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Programs Table -->
        <div class="table-section-title">
            <span><i class="fas fa-graduation-cap text-violet"></i> Academic Programs</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addProgCollapse"><i class="fas fa-plus"></i> Add Program</button>
        </div>

        <div class="collapse" id="addProgCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Create New Program</h4>
                <form asp-action="CreateProgram" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label-custom">Program Name</label>
                            <input type="text" name="ProgramName" class="form-control-portal" placeholder="e.g. BS Software Engineering" required />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Department</label>
                            <select name="DepartmentID" class="form-control-portal" required>
                                @foreach (var d in Model.Departments)
                                {
                                    <option value="@d.DepartmentID">@d.DepartmentName (@d.DepartmentCode)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Program Name</th>
                        <th>Hosting Department</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in Model.Programs)
                    {
                        <tr>
                            <td>#@p.ProgramID</td>
                            <td style="color: #fff; font-weight: 500;">@p.ProgramName</td>
                            <td>@(p.Department?.DepartmentName ?? "N/A")</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteProgram" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@p.ProgramID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Courses Table -->
        <div class="table-section-title">
            <span><i class="fas fa-book text-success"></i> Course Inventory</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addCourseCollapse"><i class="fas fa-plus"></i> Add Course</button>
        </div>

        <div class="collapse" id="addCourseCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Create New Course</h4>
                <form asp-action="CreateCourse" method="post">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Course Code</label>
                            <input type="text" name="CourseCode" class="form-control-portal" placeholder="e.g. CS-202" required />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label-custom">Course Title</label>
                            <input type="text" name="CourseTitle" class="form-control-portal" placeholder="e.g. Database Systems" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Credit Hours</label>
                            <input type="number" name="CreditHours" min="1" max="4" class="form-control-portal" value="3" required />
                        </div>
                        <div class="col-md-12 mb-2 text-end">
                            <button type="submit" class="btn-primary-custom" style="padding: 10px 24px;"><i class="fas fa-save"></i> Save Course</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Course Title</th>
                        <th>Credit Hours</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model.Courses)
                    {
                        <tr>
                            <td style="font-weight: 600; color: var(--accent-blue);">@c.CourseCode</td>
                            <td style="color: #fff; font-weight: 500;">@c.CourseTitle</td>
                            <td>@c.CreditHours Credits</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteCourse" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@c.CourseID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Sections Table -->
        <div class="table-section-title">
            <span><i class="fas fa-calendar-alt text-warning"></i> Course Sections (Spring 2025)</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addSectionCollapse"><i class="fas fa-plus"></i> Add Section</button>
        </div>

        <div class="collapse" id="addSectionCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Create New Class Section</h4>
                <form asp-action="CreateSection" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Course</label>
                            <select name="CourseID" class="form-control-portal" required>
                                @foreach (var c in Model.Courses)
                                {
                                    <option value="@c.CourseID">@c.CourseCode &mdash; @c.CourseTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Instructor</label>
                            <select name="FacultyID" class="form-control-portal" required>
                                @foreach (var f in Model.Faculty)
                                {
                                    <option value="@f.FacultyID">@f.FirstName @f.LastName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Capacity</label>
                            <input type="number" name="Capacity" class="form-control-portal" value="40" min="10" required />
                        </div>
                        <input type="hidden" name="Semester" value="Spring 2025" />
                        <div class="col-md-2 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Section ID</th>
                        <th>Course</th>
                        <th>Instructor</th>
                        <th>Semester</th>
                        <th>Capacity Limit</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Sections)
                    {
                        <tr>
                            <td>#SEC-@s.SectionID</td>
                            <td style="color: #fff; font-weight: 500;">@(s.Course?.CourseTitle ?? "N/A") (@(s.Course?.CourseCode ?? "N/A"))</td>
                            <td>@(s.Faculty != null ? s.Faculty.FirstName + " " + s.Faculty.LastName : "N/A")</td>
                            <td>@s.Semester</td>
                            <td>@s.Capacity Seats</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteSection" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@s.SectionID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- 2. PEOPLE TAB -->
    <div class="tab-pane fade" id="people" role="tabpanel">
        
        <!-- Students Table -->
        <div class="table-section-title">
            <span><i class="fas fa-user-graduate text-success"></i> Registered Students</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addStudentCollapse"><i class="fas fa-plus"></i> Register Student</button>
        </div>

        <div class="collapse" id="addStudentCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Register New Student</h4>
                <form asp-action="CreateStudent" method="post">
                    <div class="row">
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Registration No</label>
                            <input type="text" name="RegistrationNo" class="form-control-portal" placeholder="e.g. 22-CS-1004" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">First Name</label>
                            <input type="text" name="FirstName" class="form-control-portal" placeholder="Muhammad" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Last Name</label>
                            <input type="text" name="LastName" class="form-control-portal" placeholder="Ali" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Academic Program</label>
                            <select name="ProgramID" class="form-control-portal" required>
                                @foreach (var p in Model.Programs)
                                {
                                    <option value="@p.ProgramID">@p.ProgramName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label-custom">Email Address</label>
                            <input type="email" name="Email" class="form-control-portal" placeholder="ali@hitec.edu" />
                        </div>
                        <div class="col-md-6 mb-2">
                            <label class="form-label-custom">Phone Number</label>
                            <input type="text" name="Phone" class="form-control-portal" placeholder="0300-1234567" />
                        </div>
                        <div class="col-md-12 mb-2 text-end">
                            <button type="submit" class="btn-primary-custom" style="padding: 10px 24px;"><i class="fas fa-save"></i> Save Student</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Reg No</th>
                        <th>Full Name</th>
                        <th>Program</th>
                        <th>Email</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Students)
                    {
                        <tr>
                            <td>#@s.StudentID</td>
                            <td style="font-weight: 600; color: var(--accent-blue);">@s.RegistrationNo</td>
                            <td style="color: #fff; font-weight: 500;">@s.FirstName @s.LastName</td>
                            <td>@(s.Program?.ProgramName ?? "N/A")</td>
                            <td>@s.Email</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteStudent" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@s.StudentID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Faculty Table -->
        <div class="table-section-title">
            <span><i class="fas fa-chalkboard-teacher text-violet"></i> Academic Faculty</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addFacultyCollapse"><i class="fas fa-plus"></i> Add Faculty</button>
        </div>

        <div class="collapse" id="addFacultyCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Add New Faculty Member</h4>
                <form asp-action="CreateFaculty" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">First Name</label>
                            <input type="text" name="FirstName" class="form-control-portal" required />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Last Name</label>
                            <input type="text" name="LastName" class="form-control-portal" required />
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Email Address</label>
                            <input type="email" name="Email" class="form-control-portal" placeholder="name@hitec.edu" required />
                        </div>
                        <div class="col-md-12 mb-2 text-end">
                            <button type="submit" class="btn-primary-custom"><i class="fas fa-save"></i> Save Faculty</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var f in Model.Faculty)
                    {
                        <tr>
                            <td>#@f.FacultyID</td>
                            <td style="color: #fff; font-weight: 500;">@f.FirstName @f.LastName</td>
                            <td>@f.Email</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteFaculty" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@f.FacultyID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Staff Table -->
        <div class="table-section-title">
            <span><i class="fas fa-user-shield text-info"></i> Administrative Staff</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addStaffCollapse"><i class="fas fa-plus"></i> Add Staff</button>
        </div>

        <div class="collapse" id="addStaffCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Add New Staff Member</h4>
                <form asp-action="CreateStaff" method="post">
                    <div class="row">
                        <div class="col-md-8 mb-2">
                            <label class="form-label-custom">Staff Full Name</label>
                            <input type="text" name="StaffName" class="form-control-portal" placeholder="e.g. Sajid Ali" required />
                        </div>
                        <div class="col-md-4 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save Staff</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Staff Name</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model.Staffs)
                    {
                        <tr>
                            <td>#@s.StaffID</td>
                            <td style="color: #fff; font-weight: 500;">@s.StaffName</td>
                            <td style="text-align: center;">
