                                <tr>
                                    <th>ID</th>
                                    <th>Department Name</th>
                                    <th>Code</th>
                                    @if (User.IsInRole("Admin")) { <th style="width: 80px; text-align: center;">Actions</th> }
                                </tr>
                            </thead>
                            <tbody>
