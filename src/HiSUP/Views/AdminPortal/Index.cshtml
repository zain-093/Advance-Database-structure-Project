                                {
                                    <form asp-action="ReturnLibraryBook" method="post" style="display:inline;">
                                        <input type="hidden" name="id" value="@li.IssueID" />
                                        <button type="submit" class="btn-primary-custom btn-sm" style="background: linear-gradient(135deg, var(--success), #00a068); font-size: 11px; padding: 4px 10px;"><i class="fas fa-undo"></i> Return</button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Hostel Halls Table -->
        <div class="table-section-title">
            <span><i class="fas fa-hotel text-info"></i> Hostel Accommodations</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addHostelCollapse"><i class="fas fa-plus"></i> Create Hostel</button>
        </div>

        <div class="collapse" id="addHostelCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Create Hostel Hall</h4>
                <form asp-action="CreateHostel" method="post">
                    <div class="row">
                        <div class="col-md-6 mb-2">
                            <label class="form-label-custom">Hostel Name</label>
                            <input type="text" name="HostelName" class="form-control-portal" placeholder="e.g. Jinnah Hall (Boys)" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Capacity Limit</label>
                            <input type="number" name="Capacity" class="form-control-portal" value="100" min="10" required />
                        </div>
                        <div class="col-md-3 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Hostel ID</th>
                        <th>Hostel Name</th>
                        <th>Total Capacity</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in Model.Hostels)
                    {
                        <tr>
                            <td>#HST-@h.HostelID</td>
                            <td style="color: #fff; font-weight: 500;">@h.HostelName</td>
                            <td>@h.Capacity Rooms Available</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteHostel" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@h.HostelID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Hostel Allotments Table -->
        <div class="table-section-title">
            <span><i class="fas fa-bed text-warning"></i> Room Allotment list</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addAllotCollapse"><i class="fas fa-plus"></i> Allot Room</button>
        </div>

        <div class="collapse" id="addAllotCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Allot Room to Student</h4>
                <form asp-action="CreateHostelAllotment" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Student</label>
                            <select name="StudentID" class="form-control-portal" required>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.StudentID">@s.RegistrationNo &mdash; @s.FirstName @s.LastName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Hostel Hall</label>
                            <select name="HostelID" class="form-control-portal" required>
                                @foreach (var h in Model.Hostels)
                                {
                                    <option value="@h.HostelID">@h.HostelName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2 mb-2">
                            <label class="form-label-custom">Room No</label>
                            <input type="text" name="RoomNo" class="form-control-portal" placeholder="Room 101" required />
                        </div>
                        <div class="col-md-2 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Allotment ID</th>
                        <th>Student Name</th>
                        <th>Hostel Hall</th>
                        <th>Room Number</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ha in Model.HostelAllotments)
                    {
                        <tr>
                            <td>#ALT-@ha.AllotmentID</td>
                            <td style="color: #fff; font-weight: 500;">@(ha.Student?.FirstName + " " + ha.Student?.LastName)</td>
                            <td>@ha.Hostel?.HostelName</td>
                            <td style="color: var(--accent-cyan); font-weight: 600;">@ha.RoomNo</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteHostelAllotment" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@ha.AllotmentID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- 6. SCHEDULES TAB -->
    <div class="tab-pane fade" id="schedules" role="tabpanel">
        
        <!-- Exam Schedules Table -->
        <div class="table-section-title">
            <span><i class="fas fa-file-signature text-primary"></i> Mid/Final Exam Timetable</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addExamCollapse"><i class="fas fa-plus"></i> Schedule Exam</button>
        </div>

        <div class="collapse" id="addExamCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Schedule Course Exam</h4>
                <form asp-action="CreateExam" method="post">
                    <div class="row">
                        <div class="col-md-5 mb-2">
                            <label class="form-label-custom">Course</label>
                            <select name="CourseID" class="form-control-portal" required>
                                @foreach (var c in Model.Courses)
                                {
                                    <option value="@c.CourseID">@c.CourseCode &mdash; @c.CourseTitle</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Exam Date</label>
                            <input type="date" name="ExamDate" class="form-control-portal" required />
                        </div>
                        <div class="col-md-3 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Exam ID</th>
                        <th>Course Code</th>
                        <th>Course Title</th>
                        <th>Exam Date</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var es in Model.ExamSchedules)
                    {
                        <tr>
                            <td>#EX-@es.ExamID</td>
                            <td style="font-weight: 600; color: var(--accent-blue);">@es.Course?.CourseCode</td>
                            <td style="color: #fff; font-weight: 500;">@es.Course?.CourseTitle</td>
                            <td>@(es.ExamDate.HasValue ? es.ExamDate.Value.ToString("MMMM dd, yyyy") : "N/A")</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteExam" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@es.ExamID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Semester Results Table -->
        <div class="table-section-title">
            <span><i class="fas fa-poll text-success"></i> Student GPAs / Semester Results</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addResultCollapse"><i class="fas fa-plus"></i> Record GPA</button>
        </div>

        <div class="collapse" id="addResultCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Record Student GPA</h4>
                <form asp-action="CreateResult" method="post">
                    <div class="row">
                        <div class="col-md-4 mb-2">
                            <label class="form-label-custom">Student</label>
                            <select name="StudentID" class="form-control-portal" required>
                                @foreach (var s in Model.Students)
                                {
                                    <option value="@s.StudentID">@s.RegistrationNo &mdash; @s.FirstName @s.LastName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">Semester</label>
                            <input type="text" name="Semester" class="form-control-portal" value="Spring 2025" required />
                        </div>
                        <div class="col-md-3 mb-2">
                            <label class="form-label-custom">GPA (0.00 &mdash; 4.00)</label>
                            <input type="number" step="0.01" name="GPA" min="0" max="4" class="form-control-portal" required />
                        </div>
                        <div class="col-md-2 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-save"></i> Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper mb-4">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Result ID</th>
                        <th>Student Name</th>
                        <th>Semester</th>
                        <th>GPA Obtained</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Results)
                    {
                        <tr>
                            <td>#RES-@r.ResultID</td>
                            <td style="color: #fff; font-weight: 500;">@(r.Student?.FirstName + " " + r.Student?.LastName)</td>
                            <td>@r.Semester</td>
                            <td style="font-weight: 700; color: var(--accent-cyan);">@(r.GPA.HasValue ? r.GPA.Value.ToString("0.00") : "0.00")</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteResult" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@r.ResultID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Portal Notifications Table -->
        <div class="table-section-title">
            <span><i class="fas fa-bell text-warning"></i> General Portal Notifications</span>
            <button class="btn-primary-custom btn-sm" data-bs-toggle="collapse" data-bs-target="#addNotifCollapse"><i class="fas fa-plus"></i> Publish Announcement</button>
        </div>

        <div class="collapse" id="addNotifCollapse">
            <div class="form-card">
                <h4 style="font-size: 15px; margin-bottom: 16px;">Publish Portal Announcement</h4>
                <form asp-action="CreateNotification" method="post">
                    <div class="row">
                        <div class="col-md-9 mb-2">
                            <label class="form-label-custom">Announcement Message</label>
                            <input type="text" name="Message" class="form-control-portal" placeholder="e.g. Midterms are starting next week." required />
                        </div>
                        <div class="col-md-3 mb-2 d-flex align-items-end">
                            <button type="submit" class="btn-primary-custom w-100"><i class="fas fa-bullhorn"></i> Publish</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Notification ID</th>
                        <th>Announcement Description</th>
                        <th style="width: 80px; text-align: center;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in Model.Notifications)
                    {
                        <tr>
                            <td>#NTF-@n.NotificationID</td>
                            <td style="color: #fff; font-weight: 500;">@n.Message</td>
                            <td style="text-align: center;">
                                <form asp-action="DeleteNotification" method="post" onsubmit="return confirm('Are you sure?');">
                                    <input type="hidden" name="id" value="@n.NotificationID" />
                                    <button type="submit" class="btn-delete-record"><i class="fas fa-trash-alt"></i></button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

    <!-- 7. SYSTEM LOGS TAB -->
    <div class="tab-pane fade" id="logs" role="tabpanel">
        
        <div class="table-section-title">
            <span><i class="fas fa-history text-danger"></i> System Audit Trail (Fired by SQL Triggers)</span>
        </div>

        <p style="font-size: 13px; color: var(--text-secondary); margin-bottom: 16px;">
            This table reflects immediate action logs written automatically by SQL Server database triggers 
            (e.g., <code>trg_AuditStudentInsert</code>) upon data modifications.
        </p>

        <div class="data-table-wrapper">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Log ID</th>
                        <th>Table Name</th>
                        <th>Action Fired</th>
                        <th>Action Logged Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AuditLogs.Any())
                    {
                        @foreach (var log in Model.AuditLogs)
                        {
                            <tr>
                                <td>#LOG-@log.LogID</td>
                                <td style="color: #fff; font-weight: 500;">@log.TableName</td>
                                <td>
                                    <span class="badge-custom @(log.ActionType == "INSERT" ? "success" : log.ActionType == "DELETE" ? "danger" : "warning")">
                                        @log.ActionType
                                    </span>
                                </td>
                                <td>@(log.ActionDate.HasValue ? log.ActionDate.Value.ToString("MMMM dd, yyyy hh:mm:ss tt") : "N/A")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" style="text-align: center; padding: 24px; color: var(--text-muted);">
                                <i class="fas fa-info-circle"></i> Audit Log table is empty.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</div>
