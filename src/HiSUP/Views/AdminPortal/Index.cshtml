@model HiSUP.Models.AdminPortalViewModel
@{
    Layout = null;
    ViewData["Title"] = "Portal Control Panel";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HiSUP Portal Control Panel — HITEC University Student Portal Administrative Interface" />
    <title>@ViewData["Title"] — HiSUP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        /* ===== DESIGN SYSTEM & LIGHT VARIABLES ===== */
        :root {
            --primary: #4F46E5;
            --primary-light: #EEF2FF;
            --primary-dark: #3730A3;
            --accent-violet: #7C3AED;
            --accent-cyan: #06B6D4;
            --text-dark: #1E1B4B;
            --text-gray: #4B5563;
            --text-light: #9CA3AF;
            --bg-body: #F4F6FB;
            --bg-card: #FFFFFF;
            --border-light: #E5E7EB;
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --success: #10B981;
            --danger: #EF4444;
            --warning: #F59E0B;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.05);
            --shadow-md: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
            --shadow-lg: 0 10px 25px -5px rgba(79, 70, 229, 0.05), 0 8px 10px -6px rgba(79, 70, 229, 0.05);
            --transition: all 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }

        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background-color: var(--bg-body);
            color: var(--text-dark);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
        }

        a {
            color: var(--primary);
            text-decoration: none;
            transition: var(--transition);
        }

        a:hover {
            color: var(--primary-dark);
        }

        /* ===== SIDEBAR NAVIGATION ===== */
        .admin-sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: 260px;
            height: 100vh;
            background: var(--bg-card);
            border-right: 1px solid var(--border-light);
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: var(--transition);
        }

        .admin-sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .admin-brand-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--primary), var(--accent-violet));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #FFFFFF;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.15);
        }

        .admin-brand-text {
            font-size: 20px;
            font-weight: 800;
            background: linear-gradient(135deg, var(--primary), var(--accent-violet));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .admin-sidebar-user {
            padding: 20px;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            gap: 12px;
            background: #FAFBFC;
        }

        .admin-user-avatar {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--primary-light), #E0E7FF);
            color: var(--primary);
            font-weight: 700;
            font-size: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #FFFFFF;
            box-shadow: var(--shadow-sm);
        }

        .admin-user-info h4 {
            font-size: 14px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 2px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            max-width: 150px;
        }

        .admin-user-info span {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-gray);
            letter-spacing: 0.5px;
        }

        .admin-sidebar-nav {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            overflow-y: auto;
        }

        .admin-nav-section {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-light);
            padding: 12px 12px 6px;
        }

        .admin-sidebar-nav .nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            color: var(--text-gray);
            font-size: 14px;
            font-weight: 500;
            transition: var(--transition);
            border: none;
            background: transparent;
            text-align: left;
            width: 100%;
        }

        .admin-sidebar-nav .nav-link:hover {
            background: #F8F9FA;
            color: var(--primary);
        }

        .admin-sidebar-nav .nav-link.active {
            background: var(--primary-light);
            color: var(--primary);
            font-weight: 600;
            position: relative;
        }

        .admin-sidebar-nav .nav-link.active::before {
            content: '';
            position: absolute;
            left: 0;
            top: 50%;
            transform: translateY(-50%);
            width: 3px;
            height: 24px;
            background: var(--primary);
            border-radius: 0 3px 3px 0;
        }

        .admin-sidebar-nav .nav-link i {
            width: 20px;
            text-align: center;
            font-size: 15px;
        }

        .admin-sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid var(--border-light);
        }

        .btn-logout-sidebar {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: var(--radius-sm);
            color: var(--danger);
            font-size: 14px;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
        }

        .btn-logout-sidebar:hover {
            background: #FEF2F2;
            color: var(--danger);
        }

        /* ===== MAIN WORKSPACE ===== */
        .admin-main {
            margin-left: 260px;
            flex: 1;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            transition: var(--transition);
        }

        /* ===== TOP HEADER BAR ===== */
        .admin-topbar {
            height: 70px;
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 50;
        }

        .admin-topbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .sidebar-toggle-btn {
            display: none;
            background: none;
            border: none;
            font-size: 20px;
            color: var(--text-dark);
            cursor: pointer;
            padding: 4px 8px;
        }

        .admin-topbar-title {
            font-size: 18px;
            font-weight: 600;
            color: var(--text-dark);
        }

        .admin-topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        /* ===== DISSIMISSABLE ALERTS ===== */
        .alert-dismissible {
            padding-right: 3rem;
            position: relative;
        }

        /* ===== MAIN WORKSPACE CONTENT ===== */
        .admin-content {
            flex: 1;
            padding: 32px;
            max-width: 1400px;
            width: 100%;
        }

        /* ===== KPI TILES GRID ===== */
        .admin-kpi-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 16px;
            margin-bottom: 28px;
        }

        .kpi-card {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            padding: 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            box-shadow: var(--shadow-sm);
            transition: var(--transition);
        }

        .kpi-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

        .kpi-icon {
            width: 46px;
            height: 46px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #FFFFFF;
            flex-shrink: 0;
        }

        .kpi-card.blue .kpi-icon { background: linear-gradient(135deg, #3B82F6, #1D4ED8); }
        .kpi-card.emerald .kpi-icon { background: linear-gradient(135deg, #10B981, #047857); }
        .kpi-card.amber .kpi-icon { background: linear-gradient(135deg, #F59E0B, #D97706); }
        .kpi-card.violet .kpi-icon { background: linear-gradient(135deg, var(--primary), var(--accent-violet)); }
        .kpi-card.cyan .kpi-icon { background: linear-gradient(135deg, #06B6D4, #0891B2); }

        .kpi-info h5 {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            color: var(--text-light);
            margin-bottom: 2px;
            letter-spacing: 0.5px;
        }

        .kpi-value {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
        }

        /* ===== CRUDS TABLE WRAPPERS ===== */
        .table-section-title {
            font-size: 16px;
            font-weight: 700;
            color: var(--text-dark);
            margin: 28px 0 16px;
            padding-bottom: 8px;
            border-bottom: 2px solid #E5E7EB;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .table-section-title span {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .btn-primary-custom {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 8px 16px;
            background: linear-gradient(135deg, var(--primary), var(--accent-violet));
            color: #FFFFFF;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            border: none;
            transition: var(--transition);
            cursor: pointer;
        }

        .btn-primary-custom:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.2);
            color: #FFFFFF;
        }

        .btn-primary-custom.btn-sm {
            padding: 5px 12px;
            font-size: 12px;
        }

        /* ===== CRUD COLLAPSIBLE CREATION FORMS ===== */
        .form-card {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            padding: 24px;
            margin-bottom: 24px;
            box-shadow: var(--shadow-sm);
        }

        .form-label-custom {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-gray);
            margin-bottom: 8px;
            display: block;
        }

        .form-control-portal {
            width: 100%;
            height: 42px;
            background: #FAFBFC;
            border: 1.5px solid var(--border-light);
            border-radius: var(--radius-sm);
            padding: 0 14px;
            font-size: 14px;
            color: var(--text-dark);
            outline: none;
            transition: var(--transition);
        }

        .form-control-portal:focus {
            border-color: var(--primary);
            background: #FFFFFF;
            box-shadow: 0 0 0 4px rgba(79, 70, 229, 0.08);
        }

        select.form-control-portal {
            padding-right: 24px;
        }

        /* ===== PREMIUM LIGHT TABLES ===== */
        .data-table-wrapper {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
        }

        .data-table {
            width: 100%;
            border-collapse: collapse;
        }

        .data-table thead th {
            background: #FAFBFC;
            padding: 14px 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: var(--text-gray);
            border-bottom: 1px solid var(--border-light);
            text-align: left;
        }

        .data-table tbody tr {
            border-bottom: 1px solid #F3F4F6;
            transition: var(--transition);
        }

        .data-table tbody tr:last-child {
            border-bottom: none;
        }

        .data-table tbody tr:hover {
            background-color: #F9FAFB;
        }

        .data-table tbody td {
            padding: 14px 20px;
            font-size: 13.5px;
            color: var(--text-gray);
        }

        /* ===== BUTTON DELETE RECORD ===== */
        .btn-delete-record {
            background: none;
            border: none;
            color: var(--danger);
            cursor: pointer;
            padding: 6px;
            border-radius: 5px;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-delete-record:hover {
            background: #FEE2E2;
            transform: scale(1.05);
        }

        /* ===== BADGES ===== */
        .badge-custom {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 100px;
            font-size: 11.5px;
            font-weight: 600;
        }

        .badge-custom.success { background: #ECFDF5; color: var(--success); }
        .badge-custom.danger  { background: #FEF2F2; color: var(--danger); }
        .badge-custom.info    { background: #EFF6FF; color: var(--primary); }
        .badge-custom.warning { background: #FFFBEB; color: var(--warning); }

        .badge-role {
            font-size: 11px;
            font-weight: 600;
            padding: 4px 10px;
            border-radius: 100px;
        }

        .badge-role.admin { background: #EEF2FF; color: var(--primary); }
        .badge-role.faculty { background: #ECFDF5; color: var(--success); }
        .badge-role.student { background: #ECFEFF; color: var(--accent-cyan); }
        .badge-role.finance { background: #FFFBEB; color: var(--warning); }

        /* ===== AUDIT LOG TAGS ===== */
        .log-tag {
            font-family: 'SF Mono', 'Fira Code', monospace;
            font-size: 11px;
            padding: 3px 6px;
            border-radius: 4px;
        }

        /* ===== FOOTER ===== */
        .admin-footer {
            padding: 24px 32px;
            border-top: 1px solid var(--border-light);
            background: var(--bg-card);
            text-align: center;
            font-size: 12px;
            color: var(--text-light);
        }

        /* ===== MOBILE OVERLAY ===== */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.3);
            z-index: 99;
        }
        .sidebar-overlay.active { display: block; }

        /* ===== RESPONSIVE STYLING ===== */
        @@media (max-width: 1200px) {
            .admin-kpi-grid {
                grid-template-columns: repeat(3, 1fr);
            }
        }

        @@media (max-width: 991px) {
            .admin-sidebar { transform: translateX(-100%); }
            .admin-sidebar.open { transform: translateX(0); }
            .admin-main { margin-left: 0; }
            .sidebar-toggle-btn { display: block; }
            .admin-kpi-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @@media (max-width: 576px) {
            .admin-kpi-grid { grid-template-columns: 1fr; }
            .admin-content { padding: 20px 16px; }
            .admin-topbar { padding: 0 16px; }
            .table-section-title { flex-direction: column; align-items: flex-start; gap: 8px; }
            .table-section-title button { width: 100%; justify-content: center; }
        }
    </style>
</head>
<body>

    <!-- Overlay (Mobile) -->
    <div id="sidebarOverlay" class="sidebar-overlay"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside id="adminSidebar" class="admin-sidebar">
        <div class="admin-sidebar-brand">
            <div class="admin-brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <span class="admin-brand-text">HiSUP</span>
        </div>

        <div class="admin-sidebar-user">
            <div class="admin-user-avatar">
                @((User.Identity?.Name ?? "Admin").Substring(0, 1).ToUpper())
            </div>
            <div class="admin-user-info">
                <h4>@(User.Identity?.Name ?? "Administrator")</h4>
                <span>@(User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Manager")</span>
            </div>
        </div>

        <nav class="admin-sidebar-nav">
            <div class="admin-nav-section">Dashboard Panel</div>
            
            <div class="nav flex-column nav-pills" id="v-pills-tab" role="tablist" aria-orientation="vertical">
                @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                {
                    <button class="nav-link active" id="tab-academics" data-bs-toggle="pill" data-bs-target="#academics" type="button" role="tab" aria-controls="academics" aria-selected="true">
                        <i class="fas fa-university"></i> Academics
                    </button>
                    <button class="nav-link" id="tab-people" data-bs-toggle="pill" data-bs-target="#people" type="button" role="tab" aria-controls="people" aria-selected="false">
                        <i class="fas fa-users"></i> People
                    </button>
                    <button class="nav-link" id="tab-registrations" data-bs-toggle="pill" data-bs-target="#registrations" type="button" role="tab" aria-controls="registrations" aria-selected="false">
                        <i class="fas fa-clipboard-list"></i> Registrations
                    </button>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Finance"))
                {
                    <button class="nav-link @(User.IsInRole("Finance") ? "active" : "")" id="tab-finance" data-bs-toggle="pill" data-bs-target="#finance" type="button" role="tab" aria-controls="finance" aria-selected="@(User.IsInRole("Finance") ? "true" : "false")">
                        <i class="fas fa-wallet"></i> Finance
                    </button>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Library"))
                {
                    <button class="nav-link @(User.IsInRole("Library") ? "active" : "")" id="tab-services" data-bs-toggle="pill" data-bs-target="#services" type="button" role="tab" aria-controls="services" aria-selected="@(User.IsInRole("Library") ? "true" : "false")">
                        <i class="fas fa-book-reader"></i> Library
                    </button>
                }
                @if (User.IsInRole("Admin"))
                {
                    <button class="nav-link" id="tab-hostels" data-bs-toggle="pill" data-bs-target="#hostels" type="button" role="tab" aria-controls="hostels" aria-selected="false">
                        <i class="fas fa-hotel"></i> Hostels
                    </button>
                }
                @if (User.IsInRole("Admin") || User.IsInRole("Faculty"))
                {
                    <button class="nav-link" id="tab-schedules" data-bs-toggle="pill" data-bs-target="#schedules" type="button" role="tab" aria-controls="schedules" aria-selected="false">
                        <i class="fas fa-calendar-alt"></i> Schedules
                    </button>
                }
                @if (User.IsInRole("Admin"))
                {
                    <button class="nav-link" id="tab-documents" data-bs-toggle="pill" data-bs-target="#documents" type="button" role="tab" aria-controls="documents" aria-selected="false">
                        <i class="fas fa-file-alt"></i> Documents
                    </button>
                    <button class="nav-link" id="tab-logs" data-bs-toggle="pill" data-bs-target="#logs" type="button" role="tab" aria-controls="logs" aria-selected="false">
                        <i class="fas fa-shield-halved"></i> Audit Logs
                    </button>
                }
            </div>
        </nav>

        <div class="admin-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post" id="logoutForm" style="display:none;"></form>
            <a href="javascript:document.getElementById('logoutForm').submit()" class="btn-logout-sidebar" id="nav-logout">
                <i class="fas fa-right-from-bracket"></i>
                <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- ===== MAIN WORKSPACE ===== -->
    <div class="admin-main">
        <!-- Top Bar -->
        <header class="admin-topbar">
            <div class="admin-topbar-left">
                <button id="sidebarToggle" class="sidebar-toggle-btn" aria-label="Toggle sidebar menu">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="admin-topbar-title">Control Panel Dashboard</span>
            </div>
            <div class="admin-topbar-right">
                <span class="badge-role admin">
                    <i class="fas fa-user-shield"></i> System Console
                </span>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="admin-content">

            <!-- Alerts Notification -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-4 border-0" role="alert" style="background: #ECFDF5; color: var(--success); border-radius: var(--radius-sm); font-size: 14px; font-weight: 500;">
                    <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Role-based Welcome + KPI Tiles -->
            @if (User.IsInRole("Faculty"))
            {
            <div style="background: linear-gradient(135deg, #7C3AED, #4F46E5); border-radius: 16px; padding: 28px 32px; margin-bottom: 24px; color: #fff; position: relative; overflow: hidden;">
                <div style="position: absolute; top: -50%; right: -15%; width: 350px; height: 350px; background: radial-gradient(circle, rgba(255,255,255,0.08) 0%, transparent 70%); border-radius: 50%;"></div>
                <h2 style="font-size: 22px; font-weight: 700; margin-bottom: 4px; position: relative; z-index: 1;"><i class="fas fa-chalkboard-teacher me-2"></i>Welcome, @Model.FacultyName</h2>
                <p style="font-size: 14px; color: rgba(255,255,255,0.8); margin: 0; position: relative; z-index: 1;">Faculty Control Panel — Manage your assigned courses, grades, and attendance</p>
            </div>
            }

            @if (User.IsInRole("Finance"))
            {
            <div style="background: linear-gradient(135deg, #10B981, #059669); border-radius: 16px; padding: 28px 32px; margin-bottom: 24px; color: #fff; position: relative; overflow: hidden;">
