    <script>
        // Smooth scrolling & active navbar highlights
        window.addEventListener('scroll', function() {
            var nav = document.getElementById('mainNavbar');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // Numeric counters animation
        document.addEventListener('DOMContentLoaded', function() {
            var counterElements = document.querySelectorAll('.stat-number');
            
            var observer = new IntersectionObserver(function(entries) {
                entries.forEach(function(entry) {
                    if (entry.isIntersecting) {
                        var target = entry.target;
                        var countTo = parseInt(target.getAttribute('data-target'));
                        var duration = 1500; // ms
                        var start = 0;
                        var stepTime = Math.abs(Math.floor(duration / countTo));
                        stepTime = Math.max(stepTime, 20); // minimum 20ms intervals
                        
                        var timer = setInterval(function() {
                            start += Math.ceil(countTo / (duration / stepTime));
                            if (start >= countTo) {
                                target.textContent = countTo;
                                clearInterval(timer);
                            } else {
                                target.textContent = start;
                            }
                        }, stepTime);
                        
                        observer.unobserve(target);
                    }
                });
            }, { threshold: 0.5 });
            
            counterElements.forEach(function(el) {
                observer.observe(el);
            });
        });

        // Redirect helper for role login selections
        function navigateToLogin(role) {
            window.location.href = '@Url.Action("Login", "Account")';
        }
    </script>
