@model HiSUP.Models.StudentDashboardViewModel
@{
    Layout = null;
    ViewData["Title"] = "Student Dashboard";
    var initials = (Model.Student.FirstName?.Substring(0, 1) ?? "") + (Model.Student.LastName?.Substring(0, 1) ?? "");
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="HiSUP Student Dashboard — Academic overview, courses, and financial records." />
    <title>@ViewData["Title"] — HiSUP</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
          integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        /* ===== RESET & BASE ===== */
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { font-size: 16px; scroll-behavior: smooth; }
        body {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f4f6fb;
            color: #1e1b4b;
            line-height: 1.6;
            min-height: 100vh;
        }
        a { color: #4F46E5; text-decoration: none; }
        a:hover { color: #7C3AED; }

        /* ===== SIDEBAR ===== */
        .dash-sidebar {
            position: fixed;
            top: 0; left: 0;
            width: 260px;
            height: 100vh;
            background: #fff;
            border-right: 1px solid #eef0f5;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: transform 0.3s ease;
        }
        .dash-sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid #f0f0f5;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .dash-brand-icon {
            width: 40px; height: 40px;
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #fff;
        }
        .dash-brand-text {
            font-size: 20px;
            font-weight: 700;
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .dash-sidebar-nav {
            flex: 1;
            padding: 16px 12px;
            display: flex;
            flex-direction: column;
            gap: 4px;
            overflow-y: auto;
        }
        .dash-nav-section {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #9ca3af;
            padding: 16px 12px 8px;
        }
        .dash-nav-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 16px;
            border-radius: 10px;
            color: #6b7280;
            font-size: 14px;
            font-weight: 500;
            transition: all 0.2s ease;
            text-decoration: none;
            position: relative;
        }
        .dash-nav-link:hover { background: #f8f7ff; color: #4F46E5; }
        .dash-nav-link.active {
            background: #f0eeff;
            color: #4F46E5;
            font-weight: 600;
        }
        .dash-nav-link.active::before {
            content: '';
            position: absolute;
            left: 0; top: 50%;
            transform: translateY(-50%);
            width: 3px; height: 24px;
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            border-radius: 0 3px 3px 0;
        }
        .dash-nav-link i { width: 20px; text-align: center; font-size: 15px; }

        .dash-sidebar-footer {
            padding: 16px 12px;
            border-top: 1px solid #f0f0f5;
        }
        .dash-nav-link.logout { color: #dc2626; }
        .dash-nav-link.logout:hover { background: #fef2f2; color: #dc2626; }

        /* ===== MAIN AREA ===== */
        .dash-main {
            margin-left: 260px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ===== TOP BAR ===== */
        .dash-topbar {
            height: 70px;
            background: rgba(255,255,255,0.85);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border-bottom: 1px solid #eef0f5;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
            position: sticky;
            top: 0;
            z-index: 50;
        }
        .dash-topbar-left {
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .dash-topbar-title {
            font-size: 18px;
            font-weight: 600;
            color: #1e1b4b;
        }
        .dash-topbar-right {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .dash-user-badge {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 6px 16px 6px 6px;
            background: #f9fafb;
            border: 1px solid #eef0f5;
            border-radius: 100px;
            font-size: 13px;
            color: #374151;
        }
        .dash-user-avatar {
            width: 34px; height: 34px;
            border-radius: 50%;
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 600;
            color: #fff;
        }
        .sidebar-toggle-btn {
            display: none;
            background: none;
            border: none;
            font-size: 20px;
            color: #374151;
            cursor: pointer;
            padding: 4px 8px;
        }

        /* ===== CONTENT ===== */
        .dash-content {
            flex: 1;
            padding: 32px;
            max-width: 1400px;
            width: 100%;
        }

        /* ===== WELCOME BANNER ===== */
        .dash-welcome {
            background: linear-gradient(135deg, #4F46E5, #7C3AED);
            border-radius: 20px;
            padding: 32px 36px;
            margin-bottom: 28px;
            display: flex;
            align-items: center;
            gap: 24px;
            position: relative;
            overflow: hidden;
            color: #fff;
        }
        .dash-welcome::before {
            content: '';
            position: absolute;
            top: -50%; right: -20%;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            border-radius: 50%;
        }
        .dash-welcome::after {
            content: '';
            position: absolute;
            bottom: -30%; left: 40%;
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(255,255,255,0.06) 0%, transparent 70%);
            border-radius: 50%;
        }
        .dash-welcome-avatar {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(8px);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 22px;
            font-weight: 700;
            flex-shrink: 0;
            position: relative;
            z-index: 1;
            border: 2px solid rgba(255,255,255,0.3);
        }
        .dash-welcome-info { position: relative; z-index: 1; }
        .dash-welcome-info h2 {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 4px;
            color: #fff;
        }
        .dash-welcome-info p {
            font-size: 14px;
            color: rgba(255,255,255,0.8);
            margin: 0;
        }

        /* ===== STAT CARDS ===== */
        .dash-stats {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 28px;
        }
        .dash-stat-card {
            background: #fff;
            border-radius: 16px;
            padding: 24px;
            display: flex;
            align-items: flex-start;
            gap: 16px;
            border: 1px solid #f0f0f5;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        .dash-stat-card::before {
            content: '';
            position: absolute;
            left: 0; top: 0;
            width: 4px; height: 100%;
            border-radius: 0 4px 4px 0;
        }
        .dash-stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 30px rgba(0,0,0,0.06);
        }
        .dash-stat-card.blue::before   { background: linear-gradient(180deg, #4F46E5, #7C3AED); }
        .dash-stat-card.cyan::before   { background: linear-gradient(180deg, #06B6D4, #3B82F6); }
        .dash-stat-card.amber::before  { background: linear-gradient(180deg, #F59E0B, #EA580C); }
        .dash-stat-card.green::before  { background: linear-gradient(180deg, #10B981, #059669); }

        .dash-stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #fff;
            flex-shrink: 0;
        }
        .dash-stat-card.blue .dash-stat-icon   { background: linear-gradient(135deg, #4F46E5, #7C3AED); }
        .dash-stat-card.cyan .dash-stat-icon   { background: linear-gradient(135deg, #06B6D4, #3B82F6); }
        .dash-stat-card.amber .dash-stat-icon  { background: linear-gradient(135deg, #F59E0B, #EA580C); }
        .dash-stat-card.green .dash-stat-icon  { background: linear-gradient(135deg, #10B981, #059669); }

        .dash-stat-label {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #9ca3af;
            margin-bottom: 4px;
        }
        .dash-stat-value {
            font-size: 24px;
            font-weight: 700;
            color: #1e1b4b;
        }

        /* ===== SECTION CARD ===== */
        .dash-section {
            background: #fff;
            border: 1px solid #f0f0f5;
            border-radius: 16px;
            overflow: hidden;
            margin-bottom: 24px;
            transition: box-shadow 0.3s ease;
        }
        .dash-section:hover { box-shadow: 0 4px 20px rgba(0,0,0,0.04); }

        .dash-section-header {
            padding: 20px 24px;
            border-bottom: 1px solid #f0f0f5;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .dash-section-header h3 {
            font-size: 16px;
            font-weight: 600;
            color: #1e1b4b;
            display: flex;
            align-items: center;
            gap: 10px;
            margin: 0;
        }
        .dash-section-header .section-icon {
            width: 32px; height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }

        /* ===== TABLE ===== */
        .dash-table {
            width: 100%;
            border-collapse: collapse;
        }
        .dash-table thead th {
            padding: 12px 24px;
            text-align: left;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            color: #9ca3af;
            background: #fafbfc;
            border-bottom: 1px solid #f0f0f5;
        }
        .dash-table tbody tr {
            transition: background 0.15s ease;
        }
        .dash-table tbody tr:hover { background: #f9f8ff; }
        .dash-table tbody td {
            padding: 14px 24px;
            font-size: 14px;
            border-bottom: 1px solid #f8f8fb;
            color: #6b7280;
        }
        .dash-table tbody tr:last-child td { border-bottom: none; }

        /* ===== BADGES ===== */
        .dash-badge {
            display: inline-flex;
            align-items: center;
            padding: 4px 12px;
            border-radius: 100px;
            font-size: 12px;
            font-weight: 600;
        }
        .dash-badge.success { background: #ecfdf5; color: #059669; }
        .dash-badge.info    { background: #eff6ff; color: #3B82F6; }
        .dash-badge.warning { background: #fefce8; color: #ca8a04; }
        .dash-badge.danger  { background: #fef2f2; color: #dc2626; }

        /* ===== INFO CARDS (sidebar panels) ===== */
        .dash-info-card {
            background: #fff;
            border: 1px solid #f0f0f5;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 24px;
        }
        .dash-info-card h3 {
            font-size: 15px;
            font-weight: 600;
            color: #1e1b4b;
            margin-bottom: 18px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .dash-info-card .info-icon {
            width: 32px; height: 32px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            color: #fff;
        }
        .dash-info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px 0;
            border-bottom: 1px solid #f8f8fb;
        }
        .dash-info-row:last-child { border-bottom: none; }
        .dash-info-label {
            font-size: 13px;
            color: #9ca3af;
        }
        .dash-info-value {
            font-size: 14px;
            font-weight: 600;
            color: #1e1b4b;
        }

        /* ===== GRID LAYOUT ===== */
        .dash-grid { display: grid; gap: 24px; }
        .dash-grid-2 { grid-template-columns: 2fr 1fr; }
        .dash-grid-equal { grid-template-columns: 1fr 1fr; }

        /* ===== EMPTY STATE ===== */
        .dash-empty {
            text-align: center;
            padding: 40px 20px;
            color: #9ca3af;
        }
        .dash-empty i { font-size: 32px; margin-bottom: 12px; display: block; color: #d1d5db; }
        .dash-empty p { font-size: 14px; }

        /* ===== FOOTER ===== */
        .dash-footer {
            padding: 20px 32px;
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
            border-top: 1px solid #f0f0f5;
        }

        /* ===== ANIMATIONS ===== */
        .fade-up {
            opacity: 0;
            transform: translateY(16px);
            transition: opacity 0.5s ease, transform 0.5s ease;
        }
        .fade-up.visible {
            opacity: 1;
            transform: translateY(0);
        }
        .fade-up-d1 { transition-delay: 0.05s; }
        .fade-up-d2 { transition-delay: 0.1s; }
        .fade-up-d3 { transition-delay: 0.15s; }
        .fade-up-d4 { transition-delay: 0.2s; }

        /* ===== MOBILE OVERLAY ===== */
        .dash-sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.3);
            z-index: 99;
        }
        .dash-sidebar-overlay.active { display: block; }

        /* ===== RESPONSIVE ===== */
        @@media (max-width: 1100px) {
            .dash-stats { grid-template-columns: repeat(2, 1fr); }
            .dash-grid-2 { grid-template-columns: 1fr; }
            .dash-grid-equal { grid-template-columns: 1fr; }
        }
        @@media (max-width: 991px) {
            .dash-sidebar { transform: translateX(-100%); }
            .dash-sidebar.open { transform: translateX(0); }
            .dash-main { margin-left: 0; }
            .sidebar-toggle-btn { display: block; }
        }
        @@media (max-width: 640px) {
            .dash-stats { grid-template-columns: 1fr; }
            .dash-content { padding: 20px 16px; }
            .dash-topbar { padding: 0 16px; }
            .dash-welcome { flex-direction: column; text-align: center; padding: 28px 24px; }
        }
    </style>
</head>
<body>
    <!-- Overlay -->
    <div id="dashOverlay" class="dash-sidebar-overlay"></div>

    <!-- ===== SIDEBAR ===== -->
    <aside id="dashSidebar" class="dash-sidebar">
        <div class="dash-sidebar-brand">
            <div class="dash-brand-icon">
                <i class="fas fa-graduation-cap"></i>
            </div>
            <span class="dash-brand-text">HiSUP</span>
        </div>

        <nav class="dash-sidebar-nav">
            <div class="dash-nav-section">Main Menu</div>
            <a asp-controller="Home" asp-action="Index" class="dash-nav-link">
                <i class="fas fa-home"></i> <span>Home</span>
            </a>
            <a asp-controller="Dashboard" asp-action="Index" class="dash-nav-link active">
                <i class="fas fa-chart-pie"></i> <span>Dashboard</span>
            </a>
            <a asp-controller="Enrollment" asp-action="Index" class="dash-nav-link">
                <i class="fas fa-book-open"></i> <span>Enrollment</span>
            </a>

            <div class="dash-nav-section">Other</div>
            <a asp-controller="Home" asp-action="Privacy" class="dash-nav-link">
                <i class="fas fa-shield-halved"></i> <span>Privacy Policy</span>
            </a>
        </nav>

        <div class="dash-sidebar-footer">
            <form asp-controller="Account" asp-action="Logout" method="post" id="dashLogoutForm" style="display:none;"></form>
            <a href="javascript:document.getElementById('dashLogoutForm').submit()" class="dash-nav-link logout">
                <i class="fas fa-right-from-bracket"></i> <span>Logout</span>
            </a>
        </div>
    </aside>

    <!-- ===== MAIN ===== -->
    <div class="dash-main">
        <!-- Top Bar -->
        <header class="dash-topbar">
            <div class="dash-topbar-left">
                <button id="dashSidebarToggle" class="sidebar-toggle-btn" aria-label="Toggle sidebar">
                    <i class="fas fa-bars"></i>
                </button>
                <span class="dash-topbar-title">Student Dashboard</span>
            </div>
            <div class="dash-topbar-right">
                <div class="dash-user-badge">
                    <div class="dash-user-avatar">@initials</div>
                    <span>@Model.Student.FirstName @Model.Student.LastName</span>
                </div>
            </div>
        </header>

        <!-- Content -->
        <main class="dash-content">

            <!-- Welcome Banner -->
            <div class="dash-welcome fade-up">
                <div class="dash-welcome-avatar">@initials</div>
                <div class="dash-welcome-info">
                    <h2>Welcome back, @Model.Student.FirstName!</h2>
                    <p>Here's your academic overview for <strong>@Model.ProgramName</strong> — @Model.DepartmentName Department</p>
                </div>
            </div>

            <!-- Stats Cards -->
            <div class="dash-stats">
                <div class="dash-stat-card blue fade-up fade-up-d1">
                    <div class="dash-stat-icon"><i class="fas fa-graduation-cap"></i></div>
                    <div>
                        <div class="dash-stat-label">CGPA</div>
                        <div class="dash-stat-value">@Model.CGPA.ToString("0.00")</div>
                    </div>
                </div>
                <div class="dash-stat-card cyan fade-up fade-up-d2">
                    <div class="dash-stat-icon"><i class="fas fa-book"></i></div>
                    <div>
                        <div class="dash-stat-label">Enrolled Courses</div>
                        <div class="dash-stat-value">@Model.EnrolledCoursesCount</div>
                    </div>
                </div>
                <div class="dash-stat-card amber fade-up fade-up-d3">
                    <div class="dash-stat-icon"><i class="fas fa-wallet"></i></div>
                    <div>
                        <div class="dash-stat-label">Outstanding Fee</div>
                        <div class="dash-stat-value">Rs. @Model.OutstandingFee.ToString("N0")</div>
                    </div>
                </div>
                <div class="dash-stat-card green fade-up fade-up-d4">
                    <div class="dash-stat-icon"><i class="fas fa-calendar-check"></i></div>
                    <div>
                        <div class="dash-stat-label">Attendance</div>
                        <div class="dash-stat-value">@Model.AttendancePercentage.ToString("0")%</div>
                    </div>
                </div>
            </div>

            <!-- Main Grid: Courses + Side Info -->
            <div class="dash-grid dash-grid-2">
                <!-- Enrolled Courses Table -->
                <div class="dash-section fade-up">
                    <div class="dash-section-header">
                        <div class="section-icon" style="background: linear-gradient(135deg, #4F46E5, #7C3AED);">
                            <i class="fas fa-university"></i>
                        </div>
                        <h3>Enrolled Courses</h3>
                    </div>
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Code</th>
                                <th>Course Title</th>
                                <th>Credits</th>
                                <th>Instructor</th>
                                <th>Marks</th>
                                <th>Grade</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Enrollments.Any())
                            {
                                @foreach (var record in Model.Enrollments)
                                {
                                    <tr>
                                        <td style="font-weight: 600; color: #4F46E5;">@record.CourseCode</td>
                                        <td style="color: #1e1b4b; font-weight: 500;">@record.CourseTitle</td>
                                        <td>@record.CreditHours</td>
                                        <td>@record.FacultyName</td>
                                        <td>@(record.Marks.HasValue ? record.Marks.Value.ToString("0.0") : "N/A")</td>
                                        <td>
                                            <span class="dash-badge @(record.LetterGrade == "A" ? "success" : record.LetterGrade == "B" ? "info" : "warning")">
                                                @record.LetterGrade
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6">
                                        <div class="dash-empty">
                                            <i class="fas fa-inbox"></i>
                                            <p>No active course enrollments found.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Right Column -->
                <div>
                    <!-- Hostel Card -->
                    <div class="dash-info-card fade-up">
                        <h3>
                            <div class="info-icon" style="background: linear-gradient(135deg, #7C3AED, #9333EA);">
                                <i class="fas fa-hotel"></i>
                            </div>
                            Hostel Accommodation
                        </h3>
                        <div class="dash-info-row">
                            <span class="dash-info-label">Hostel Hall</span>
                            <span class="dash-info-value">@Model.HostelName</span>
                        </div>
                        <div class="dash-info-row">
                            <span class="dash-info-label">Room Number</span>
                            <span class="dash-info-value" style="color: #4F46E5;">@Model.RoomNo</span>
                        </div>
                    </div>

                    <!-- Registration Details -->
                    <div class="dash-info-card fade-up">
                        <h3>
                            <div class="info-icon" style="background: linear-gradient(135deg, #06B6D4, #3B82F6);">
                                <i class="fas fa-id-card"></i>
                            </div>
                            Registration Details
                        </h3>
                        <div class="dash-info-row">
                            <span class="dash-info-label">Reg No</span>
                            <span class="dash-info-value">@Model.Student.RegistrationNo</span>
                        </div>
                        <div class="dash-info-row">
                            <span class="dash-info-label">Phone</span>
                            <span class="dash-info-value">@Model.Student.Phone</span>
                        </div>
                        <div class="dash-info-row">
                            <span class="dash-info-label">Email</span>
                            <span class="dash-info-value" style="font-size: 12px;">@Model.Student.Email</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom Grid: Library + Fees -->
            <div class="dash-grid dash-grid-equal">
                <!-- Library Books -->
                <div class="dash-section fade-up">
                    <div class="dash-section-header">
                        <div class="section-icon" style="background: linear-gradient(135deg, #7C3AED, #9333EA);">
                            <i class="fas fa-book"></i>
                        </div>
                        <h3>Library Books Borrowed</h3>
                    </div>
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Book Title</th>
                                <th>Author</th>
                                <th>Issue Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.LibraryIssues.Any())
                            {
                                @foreach (var record in Model.LibraryIssues)
                                {
                                    <tr>
                                        <td style="color: #1e1b4b; font-weight: 500;">@record.Title</td>
                                        <td>@record.Author</td>
                                        <td>@record.IssueDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            <span class="dash-badge @(record.Status == "Returned" ? "success" : "warning")">
                                                @record.Status
                                            </span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">
                                        <div class="dash-empty">
                                            <i class="fas fa-book-open"></i>
                                            <p>No library books currently borrowed.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Fee Payments -->
                <div class="dash-section fade-up">
                    <div class="dash-section-header">
                        <div class="section-icon" style="background: linear-gradient(135deg, #10B981, #059669);">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <h3>Fee Payments</h3>
                    </div>
                    <table class="dash-table">
                        <thead>
                            <tr>
                                <th>Payment ID</th>
                                <th>Amount Paid</th>
                                <th>Payment Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.FeePayments.Any())
                            {
                                @foreach (var record in Model.FeePayments)
                                {
                                    <tr>
                                        <td style="font-weight: 600;">#FP-@record.PaymentID</td>
                                        <td style="color: #059669; font-weight: 600;">Rs. @(record.AmountPaid.HasValue ? record.AmountPaid.Value.ToString("N2") : "0.00")</td>
                                        <td>@(record.PaymentDate.HasValue ? record.PaymentDate.Value.ToString("MMM dd, yyyy") : "N/A")</td>
                                        <td>
                                            <span class="dash-badge success">Paid</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4">
                                        <div class="dash-empty">
                                            <i class="fas fa-receipt"></i>
                                            <p>No fee payments recorded.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

        </main>

        <footer class="dash-footer">
            &copy; 2026 HiSUP &mdash; HITEC University Student Portal
        </footer>
    </div>

    <script>
        // Sidebar toggle
        document.addEventListener('DOMContentLoaded', function () {
            var toggle = document.getElementById('dashSidebarToggle');
            var sidebar = document.getElementById('dashSidebar');
            var overlay = document.getElementById('dashOverlay');

            if (toggle) {
                toggle.addEventListener('click', function () {
                    sidebar.classList.toggle('open');
                    overlay.classList.toggle('active');
                });
            }
            if (overlay) {
                overlay.addEventListener('click', function () {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('active');
                });
            }

            // Scroll animations
            var fadeEls = document.querySelectorAll('.fade-up');
            if (fadeEls.length) {
                var obs = new IntersectionObserver(function (entries) {
                    entries.forEach(function (e) {
                        if (e.isIntersecting) e.target.classList.add('visible');
                    });
                }, { threshold: 0.1, rootMargin: '0px 0px -30px 0px' });
                fadeEls.forEach(function (el) { obs.observe(el); });
            }
        });
    </script>
</body>
</html>